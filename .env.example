# DeepSeek API (https://api-docs.deepseek.com)
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat

# Session cookie signing key — use a long random string
SESSION_SECRET=change-this-to-a-random-string

# Admin credentials
ADMIN_USERNAME=admin
# Generate with: htpasswd -bnBC 10 "" yourpassword | tr -d ':\n'
ADMIN_PASSWORD_HASH=$2a$10$replace-with-real-bcrypt-hash

# Server
PORT=8080

# Path for SQLite DB
DATA_DIR=./data

# Path for uploaded PDFs and generated HTML
STORAGE_DIR=./storage

# Python interpreter (change if python3 is not in PATH)
PYTHON_BIN=python3

# Path to PDF extractor script
PARSER_SCRIPT=parser/extract.py
